{
  "schema_version": 1,
  "id": "aider",
  "name": "Aider",
  "detect": {
    "windows": {
      "command": "aider",
      "args": [
        "--version"
      ]
    },
    "macos": {
      "command": "aider",
      "args": [
        "--version"
      ]
    },
    "linux": {
      "command": "aider",
      "args": [
        "--version"
      ]
    }
  },
  "install": {
    "windows": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "aider-chat"
      ]
    },
    "macos": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "aider-chat"
      ]
    },
    "linux": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "aider-chat"
      ]
    }
  },
  "update": {
    "windows": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "aider-chat"
      ]
    },
    "macos": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "aider-chat"
      ]
    },
    "linux": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "aider-chat"
      ]
    }
  },
  "uninstall": {
    "windows": {
      "command": "uv",
      "args": [
        "tool",
        "uninstall",
        "aider-chat"
      ]
    },
    "macos": {
      "command": "uv",
      "args": [
        "tool",
        "uninstall",
        "aider-chat"
      ]
    },
    "linux": {
      "command": "uv",
      "args": [
        "tool",
        "uninstall",
        "aider-chat"
      ]
    }
  },
  "run": {
    "windows": {
      "command": "aider",
      "args": []
    },
    "macos": {
      "command": "aider",
      "args": []
    },
    "linux": {
      "command": "aider",
      "args": []
    }
  },
  "providers": [
    "native",
    "openrouter",
    "lmstudio-local"
  ],
  "provider_recipes": {
    "native": {
      "env": {},
      "args": [
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "openrouter/anthropic/claude-sonnet-4.5"
      }
    },
    "openrouter": {
      "env": {
        "OPENROUTER_API_KEY": "{api_key}"
      },
      "args": [
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "openrouter/anthropic/claude-sonnet-4.5"
      }
    },
    "lmstudio-local": {
      "env": {
        "OPENAI_API_KEY": "lm-studio",
        "OPENAI_BASE_URL": "{base_url}/v1"
      },
      "args": [
        "--model",
        "openai/{model}"
      ],
      "defaults": {
        "base_url": "http://127.0.0.1:1234",
        "model": "qwen3-coder-30b"
      }
    }
  },
  "default_model": "openrouter/anthropic/claude-sonnet-4.5"
}
