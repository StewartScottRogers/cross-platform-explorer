{
  "schema_version": 1,
  "id": "codex",
  "name": "OpenAI Codex CLI",
  "detect": {
    "windows": {
      "command": "codex",
      "args": [
        "--version"
      ]
    },
    "macos": {
      "command": "codex",
      "args": [
        "--version"
      ]
    },
    "linux": {
      "command": "codex",
      "args": [
        "--version"
      ]
    }
  },
  "install": {
    "windows": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@openai/codex@latest"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@openai/codex@latest"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@openai/codex@latest"
      ]
    }
  },
  "update": {
    "windows": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@openai/codex@latest"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@openai/codex@latest"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@openai/codex@latest"
      ]
    }
  },
  "uninstall": {
    "windows": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@openai/codex"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@openai/codex"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@openai/codex"
      ]
    }
  },
  "run": {
    "windows": {
      "command": "codex",
      "args": []
    },
    "macos": {
      "command": "codex",
      "args": []
    },
    "linux": {
      "command": "codex",
      "args": []
    }
  },
  "providers": [
    "native",
    "openrouter",
    "lmstudio-local"
  ],
  "provider_recipes": {
    "native": {
      "env": {},
      "args": [
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "gpt-5.5"
      }
    },
    "openrouter": {
      "env": {
        "OPENROUTER_API_KEY": "{api_key}"
      },
      "args": [
        "-c",
        "model_provider=openrouter",
        "-c",
        "model_providers.openrouter.name=OpenRouter",
        "-c",
        "model_providers.openrouter.base_url=https://openrouter.ai/api/v1",
        "-c",
        "model_providers.openrouter.env_key=OPENROUTER_API_KEY",
        "-c",
        "model_providers.openrouter.wire_api=responses",
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "openai/gpt-5.1-codex"
      }
    },
    "lmstudio-local": {
      "env": {
        "LMSTUDIO_API_KEY": "lm-studio"
      },
      "args": [
        "-c",
        "model_provider=lmstudio",
        "-c",
        "model_providers.lmstudio.base_url={base_url}/v1",
        "-c",
        "model_providers.lmstudio.env_key=LMSTUDIO_API_KEY",
        "-c",
        "model_providers.lmstudio.wire_api=chat",
        "--model",
        "{model}"
      ],
      "defaults": {
        "base_url": "http://127.0.0.1:1234",
        "model": "qwen3-coder-30b"
      }
    }
  },
  "default_model": "gpt-5.5"
}
