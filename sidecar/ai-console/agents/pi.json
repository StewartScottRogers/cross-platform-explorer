{
  "schema_version": 1,
  "id": "pi",
  "name": "Pi Coding Agent",
  "detect": {
    "windows": {
      "command": "pi",
      "args": [
        "--version"
      ]
    },
    "macos": {
      "command": "pi",
      "args": [
        "--version"
      ]
    },
    "linux": {
      "command": "pi",
      "args": [
        "--version"
      ]
    }
  },
  "install": {
    "windows": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "--ignore-scripts",
        "@earendil-works/pi-coding-agent@latest"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "--ignore-scripts",
        "@earendil-works/pi-coding-agent@latest"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "--ignore-scripts",
        "@earendil-works/pi-coding-agent@latest"
      ]
    }
  },
  "update": {
    "windows": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "--ignore-scripts",
        "@earendil-works/pi-coding-agent@latest"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "--ignore-scripts",
        "@earendil-works/pi-coding-agent@latest"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "--ignore-scripts",
        "@earendil-works/pi-coding-agent@latest"
      ]
    }
  },
  "uninstall": {
    "windows": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@earendil-works/pi-coding-agent"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@earendil-works/pi-coding-agent"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@earendil-works/pi-coding-agent"
      ]
    }
  },
  "run": {
    "windows": {
      "command": "pi",
      "args": []
    },
    "macos": {
      "command": "pi",
      "args": []
    },
    "linux": {
      "command": "pi",
      "args": []
    }
  },
  "providers": [
    "native",
    "openrouter",
    "lmstudio-local"
  ],
  "provider_recipes": {
    "native": {
      "env": {},
      "args": [
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "anthropic/claude-sonnet-4.5"
      }
    },
    "openrouter": {
      "env": {
        "OPENROUTER_API_KEY": "{api_key}"
      },
      "args": [
        "--provider",
        "openrouter",
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "anthropic/claude-sonnet-4.5"
      }
    },
    "lmstudio-local": {
      "env": {
        "OPENAI_API_KEY": "lm-studio",
        "OPENAI_BASE_URL": "{base_url}/v1"
      },
      "args": [
        "--provider",
        "openai",
        "--model",
        "{model}"
      ],
      "defaults": {
        "base_url": "http://127.0.0.1:1234",
        "model": "qwen3-coder-30b"
      }
    }
  },
  "default_model": "anthropic/claude-sonnet-4.5"
}
