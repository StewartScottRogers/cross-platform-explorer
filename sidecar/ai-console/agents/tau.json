{
  "schema_version": 1,
  "id": "tau",
  "name": "Tau",
  "detect": {
    "windows": {
      "command": "tau",
      "args": [
        "--version"
      ]
    },
    "macos": {
      "command": "tau",
      "args": [
        "--version"
      ]
    },
    "linux": {
      "command": "tau",
      "args": [
        "--version"
      ]
    }
  },
  "install": {
    "windows": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "tau-ai"
      ]
    },
    "macos": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "tau-ai"
      ]
    },
    "linux": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "tau-ai"
      ]
    }
  },
  "update": {
    "windows": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "tau-ai"
      ]
    },
    "macos": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "tau-ai"
      ]
    },
    "linux": {
      "command": "uv",
      "args": [
        "tool",
        "install",
        "--upgrade",
        "tau-ai"
      ]
    }
  },
  "uninstall": {
    "windows": {
      "command": "uv",
      "args": [
        "tool",
        "uninstall",
        "tau-ai"
      ]
    },
    "macos": {
      "command": "uv",
      "args": [
        "tool",
        "uninstall",
        "tau-ai"
      ]
    },
    "linux": {
      "command": "uv",
      "args": [
        "tool",
        "uninstall",
        "tau-ai"
      ]
    }
  },
  "run": {
    "windows": {
      "command": "tau",
      "args": []
    },
    "macos": {
      "command": "tau",
      "args": []
    },
    "linux": {
      "command": "tau",
      "args": []
    }
  },
  "providers": [
    "native",
    "openrouter"
  ],
  "provider_recipes": {
    "native": {
      "env": {},
      "args": [
        "--provider",
        "anthropic",
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "claude-sonnet-4-6"
      }
    },
    "openrouter": {
      "env": {
        "OPENROUTER_API_KEY": "{api_key}"
      },
      "args": [
        "--provider",
        "openrouter",
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "anthropic/claude-sonnet-4.5"
      }
    }
  },
  "default_model": "claude-sonnet-4-6"
}
