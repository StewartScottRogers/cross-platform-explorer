{
  "schema_version": 1,
  "id": "qwen",
  "name": "Qwen Code",
  "detect": {
    "windows": {
      "command": "qwen",
      "args": [
        "--version"
      ]
    },
    "macos": {
      "command": "qwen",
      "args": [
        "--version"
      ]
    },
    "linux": {
      "command": "qwen",
      "args": [
        "--version"
      ]
    }
  },
  "install": {
    "windows": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@qwen-code/qwen-code@latest"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@qwen-code/qwen-code@latest"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@qwen-code/qwen-code@latest"
      ]
    }
  },
  "update": {
    "windows": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@qwen-code/qwen-code@latest"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@qwen-code/qwen-code@latest"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "i",
        "-g",
        "@qwen-code/qwen-code@latest"
      ]
    }
  },
  "uninstall": {
    "windows": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@qwen-code/qwen-code"
      ]
    },
    "macos": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@qwen-code/qwen-code"
      ]
    },
    "linux": {
      "command": "npm",
      "args": [
        "rm",
        "-g",
        "@qwen-code/qwen-code"
      ]
    }
  },
  "run": {
    "windows": {
      "command": "qwen",
      "args": []
    },
    "macos": {
      "command": "qwen",
      "args": []
    },
    "linux": {
      "command": "qwen",
      "args": []
    }
  },
  "providers": [
    "native",
    "openrouter",
    "lmstudio-local"
  ],
  "provider_recipes": {
    "native": {
      "env": {},
      "args": []
    },
    "openrouter": {
      "env": {
        "OPENAI_API_KEY": "{api_key}",
        "OPENAI_BASE_URL": "https://openrouter.ai/api/v1",
        "OPENAI_MODEL": "{model}"
      },
      "args": [
        "--model",
        "{model}"
      ],
      "defaults": {
        "model": "qwen/qwen3-coder"
      }
    },
    "lmstudio-local": {
      "env": {
        "OPENAI_BASE_URL": "{base_url}/v1",
        "OPENAI_API_KEY": "lm-studio",
        "OPENAI_MODEL": "{model}"
      },
      "args": [],
      "defaults": {
        "base_url": "http://127.0.0.1:1234",
        "model": "qwen3-coder-30b"
      }
    }
  },
  "default_model": "qwen/qwen3-coder"
}
