{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window and the torn-off preview window.",
  "windows": ["main", "preview-float"],
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "core:event:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "opener:default",
    "opener:allow-open-path",
    "dialog:default",
    "process:default",
    "updater:default",
    "window-state:default"
  ]
}
