{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cross-Platform Explorer",
  "version": "0.1.0",
  "identifier": "com.example.crossplatformexplorer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cross-Platform Explorer",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/StewartScottRogers/cross-platform-explorer/releases/latest/download/latest.json"
      ]
    }
  }
}
