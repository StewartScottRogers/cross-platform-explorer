{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cross-Platform Explorer",
  "version": "0.57.1",
  "identifier": "com.example.crossplatformexplorer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "cli": {
      "description": "Cross-Platform Explorer — window geometry launch options (CPE-580).",
      "longDescription": "Position and size the window at launch. Values are logical pixels (stable across DPI) unless --physical. Precedence: CLI flag > saved window state > default. Off-screen/oversized values are clamped onto the monitor with a warning.",
      "args": [
        { "name": "x", "takesValue": true, "description": "Window left position (logical px)" },
        { "name": "y", "takesValue": true, "description": "Window top position (logical px)" },
        { "name": "width", "takesValue": true, "description": "Window width (logical px)" },
        { "name": "height", "takesValue": true, "description": "Window height (logical px)" },
        { "name": "position", "takesValue": true, "description": "Preset: top-left|top-right|bottom-left|bottom-right|center (explicit --x/--y override it)" },
        { "name": "monitor", "takesValue": true, "description": "Target monitor index (0-based)" },
        { "name": "maximized", "takesValue": false, "description": "Start maximized" },
        { "name": "fullscreen", "takesValue": false, "description": "Start fullscreen" },
        { "name": "physical", "takesValue": false, "description": "Treat --x/--y/--width/--height as physical pixels" }
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyMUU1NzRGNjhFMjU2MUEKUldRYVZ1Sm9UMWNlVXYvc283NmRaeHVhYkQrNGpQKzZ5aitWL1ErWWRxUGFWRXlQdXJDTkNENG4K",
      "endpoints": [
        "https://github.com/StewartScottRogers/cross-platform-explorer/releases/latest/download/latest.json"
      ]
    }
  }
}
